{
  "manifest_version": 3,
  "name": "TubeBrain",
  "version": "2.2.0",
  "version_name": "2.2.0",
  "description": "Trasforma YouTube in una piattaforma di apprendimento con riassunti AI, note Markdown, screening automatico e workflow per agenti IDE.",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "scripting",
    "contextMenus",
    "tabs",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://api.openai.com/*",
    "*://generativelanguage.googleapis.com/*",
    "*://www.youtube.com/feeds/*",
    "*://www.googleapis.com/*",
    "*://*.vimeo.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["utils/sanitize.js", "content-script.js", "ocr-content.js"],
      "css": ["ocr-content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "TubeBrain",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dashboard/dashboard.html",
        "utils/spaced-repetition.js",
        "utils/adaptive-quiz.js",
        "utils/progress-tracker.js",
        "utils/annotations.js",
        "utils/study-set.js",
        "utils/pomodoro.js",
        "utils/tts.js",
        "icons/*.png",
        "ocr-lib/tesseract.min.js",
        "ocr-lib/worker.min.js",
        "ocr-lib/tesseract-core-simd-lstm.wasm.js",
        "ocr-lib/tesseract-core-simd-lstm.wasm",
        "ocr-lib/tesseract-core-simd.wasm.js",
        "ocr-lib/tesseract-core-simd.wasm",
        "ocr-lib/tesseract-core.wasm.js",
        "ocr-lib/tesseract-core.wasm",
        "ocr-lib/eng.traineddata.gz",
        "ocr-lib/ita.traineddata.gz",
        "ocr-lib/lang-data/eng/eng.traineddata.gz",
        "ocr-lib/lang-data/ita/ita.traineddata.gz",
        "ocr-lib/*.special-words",
        "ocr/ocr.html",
        "ocr/ocr-host.js",
        "ocr/ocr-worker-bootstrap.js",
        "ocr/ocr-host.html",
        "ocr/tesseract-loader.js",
        "ocr/ocr-worker.js"
      ],
      "matches": [
        "*://*.youtube.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "commands": {
    "start-selection": {
      "suggested_key": {
        "default": "Ctrl+Shift+O",
        "mac": "Command+Shift+O"
      },
      "description": "Avvia selezione OCR su video"
    },
    "toggle-queue": {
      "suggested_key": {
        "default": "Alt+Q"
      },
      "description": "Aggiungi video alla coda"
    },
    "add-to-queue": {
      "suggested_key": {
        "mac": "Command+Shift+P",
        "windows": "Ctrl+Shift+P",
        "linux": "Ctrl+Shift+P"
      },
      "description": "Claude_Chrome-PlugIn_YouTube-Learn: Accoda il video e segue il creator"
    }
  }
}
